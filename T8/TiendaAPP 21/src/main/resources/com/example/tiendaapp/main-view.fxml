<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>


<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0"
            prefWidth="500.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.tiendaapp.MainController">
    <top>
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Primera app javafxt" textAlignment="CENTER" BorderPane.alignment="CENTER">
            <font>
                <Font name="Bookman Old Style" size="18.0" />
            </font>
        </Text>
    </top>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <center>
        <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <TextField fx:id="editNombre" prefHeight="0.0" prefWidth="460.0" promptText="Introduce tu nombre">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                    <font>
                        <Font name="Britannic Bold" size="13.0" />
                    </font>
                </TextField>
                <Button fx:id="botonSaludar" mnemonicParsing="false" style="-fx-background-color: grey;" text="Saludar" textFill="#650d0d">
                    <font>
                        <Font name="Broadway" size="12.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
            </children>
        </VBox>
    </center>
    <bottom>
        <Text fx:id="textoSaludo" strokeType="OUTSIDE" strokeWidth="0.0" BorderPane.alignment="CENTER" />
    </bottom>
</BorderPane>
